# ===========================================
# HyliLabs Backend Environment Variables
# ===========================================

# ------------------------------------------
# AI Model API Keys (at least one required)
# ------------------------------------------

# Google Gemini (Primary for CV Intelligence & V3 Scoring)
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude (CV Parsing & V3 Fallback)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI (V3 Fallback)
OPENAI_API_KEY=your_openai_api_key_here

# ------------------------------------------
# Optional: Nous Research Hermes
# ------------------------------------------
HERMES_API_URL=http://localhost:8642

# ------------------------------------------
# Database Configuration
# ------------------------------------------
DATABASE_URL=sqlite:///./data/talentflow.db

# ------------------------------------------
# Security
# ------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_generate_with_openssl

# JWT token expiration in minutes
JWT_EXPIRATION_MINUTES=1440

# ------------------------------------------
# Email Configuration (Optional)
# ------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# ------------------------------------------
# Application Settings
# ------------------------------------------
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
